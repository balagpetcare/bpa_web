# ─────────────────────────────────────────────────────────────────────────────
# BPA Web (Public Site) — Production Environment Variables
# Copy to .env.local on the production server. Never commit the filled-in file.
#
# Note: NEXT_PUBLIC_* vars are baked into the client bundle at build time.
# Rebuild the app after changing any of these values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ─── Backend API ─────────────────────────────────────────────────────────────
# No trailing slash.
BACKEND_API_URL=https://api.bangladeshpetassociation.com/api/v1
NEXT_PUBLIC_API_URL=https://api.bangladeshpetassociation.com/api/v1

# ─── Media ───────────────────────────────────────────────────────────────────
# Must match MEDIA_PUBLIC_BASE_URL in backend-api .env.
# No trailing slash.
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.bangladeshpetassociation.com

# ─── Site Identity ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bangladeshpetassociation.com

# ─── Google Tag Manager (recommended — manages GA4, Ads, Pixel via one tag) ──
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# ─── Google Analytics 4 (direct snippet — skip if managed via GTM) ───────────
# Warning: setting both GTM_ID and GA_ID causes double-counting.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ─── Meta (Facebook) Pixel (skip if managed via GTM) ─────────────────────────
# Format: numeric Pixel ID e.g. 1234567890123456
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Google Search Console domain verification ────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Meta / Facebook domain verification ─────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# ─── Google Ads conversion tracking (optional, GTM preferred) ────────────────
# Format: AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ─── Social Login feature flags ──────────────────────────────────────────────
# Controls whether OAuth buttons appear on sign-in/sign-up pages.
# Must also configure corresponding OAuth credentials in backend-api .env.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=true
NEXT_PUBLIC_AUTH_INSTAGRAM_ENABLED=false
NEXT_PUBLIC_AUTH_TWITTER_ENABLED=false
